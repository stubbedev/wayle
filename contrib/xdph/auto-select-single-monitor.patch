-        SHAREDATA = promptForScreencopySelection();
+        // Auto-select the only monitor when the client asks for monitors but
+        // not windows (e.g. Chrome's "Entire screen") and exactly one output
+        // exists. The choice is then unambiguous, so the picker adds nothing.
+        static auto* const* PAUTOSELECT =
+            (Hyprlang::INT* const*)g_pPortalManager->m_sConfig.config->getConfigValuePtr("screencopy:auto_select_single_monitor")->getDataStaticPtr();
+
+        const bool MONITORONLY = (requestedTypes & MONITOR) && !(requestedTypes & WINDOW);
+
+        if (**PAUTOSELECT && MONITORONLY && g_pPortalManager->outputCount() == 1) {
+            Debug::log(LOG, "[screencopy] auto-selecting the single monitor, not prompting");
+            SHAREDATA.type   = TYPE_OUTPUT;
+            SHAREDATA.output = g_pPortalManager->firstOutputName();
+        } else {
+            Debug::log(LOG, "[screencopy] restore data invalid / missing, prompting");
+            SHAREDATA = promptForScreencopySelection();
+        }
     }
 
     Debug::log(LOG, "[screencopy] SHAREDATA returned selection {}", (int)SHAREDATA.type);
