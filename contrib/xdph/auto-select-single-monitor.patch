+    uint32_t requestedTypes = MONITOR | WINDOW | VIRTUAL;
+
     for (auto& [key, val] : options) {
 
-        if (key == "cursor_mode") {
+        if (key == "types") {
+            requestedTypes = val.get<uint32_t>();
+            Debug::log(LOG, "[screencopy] option types to {}", requestedTypes);
+        } else if (key == "cursor_mode") {
             PSESSION->cursorMode = val.get<uint32_t>();
             Debug::log(LOG, "[screencopy] option cursor_mode to {}", PSESSION->cursorMode);
         } else if (key == "restore_data") {
@@ -210,9 +217,22 @@ dbUasv CScreencopyPortal::onSelectSources(sdbus::ObjectPath requestHandle, sdbus
             SHAREDATA.h = restoreData.geometry.h;
         }
     } else {
