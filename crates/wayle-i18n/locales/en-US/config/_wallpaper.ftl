### Wayle Configuration - Wallpaper Settings

## Wallpaper

settings-wallpaper-wallpaper = Wallpaper Image
    .description = A single image file to use on all monitors (leave empty for cycling / per-monitor)

settings-wallpaper-fit-mode = Scaling
    .description = How the wallpaper is scaled to the screen (fill, fit, center, stretch)

## Cycling

settings-wallpaper-cycling-enabled = Cycling Enabled
    .description = Automatically cycle through wallpapers in a directory

settings-wallpaper-cycling-directory = Cycling Directory
    .description = Directory containing wallpaper images

settings-wallpaper-cycling-mode = Cycling Mode
    .description = Wallpaper cycling order (sequential or shuffle)

settings-wallpaper-cycling-interval-mins = Cycling Interval
    .description = Time between wallpaper changes in minutes

settings-wallpaper-cycling-same-image = Same Image On All Monitors
    .description = Show the same cycling wallpaper on all monitors (only affects shuffle mode)

settings-wallpaper-monitors = Monitor Wallpapers
    .description = Per-monitor wallpaper assignments


## FitMode variants
enum-fit-mode-fill = Fill
enum-fit-mode-fit = Fit
enum-fit-mode-center = Center
enum-fit-mode-stretch = Stretch

## CyclingMode variants
enum-cycling-mode-sequential = Sequential
enum-cycling-mode-shuffle = Shuffle
