### Wayle Configuration - Power Profiles Module

## Power Profiles Module Configuration

settings-modules-power-profiles-format = Format
    .description = Label format string. Placeholders: {"{{ profile }}"}

settings-modules-power-profiles-icon-power-saver = Power Saver Icon
    .description = Icon shown while the power-saver profile is active

settings-modules-power-profiles-icon-balanced = Balanced Icon
    .description = Icon shown while the balanced profile is active

settings-modules-power-profiles-icon-performance = Performance Icon
    .description = Icon shown while the performance profile is active

settings-modules-power-profiles-color-power-saver = Power Saver Color
    .description = Icon and label color while the power-saver profile is active

settings-modules-power-profiles-color-balanced = Balanced Color
    .description = Icon and label color while the balanced profile is active

settings-modules-power-profiles-color-performance = Performance Color
    .description = Icon and label color while the performance profile is active

settings-modules-power-profiles-border-show = Show Border
    .description = Display border around button

settings-modules-power-profiles-border-color = Border Color
    .description = Border color token

settings-modules-power-profiles-icon-show = Show Icon
    .description = Display module icon

settings-modules-power-profiles-icon-color = Icon Color
    .description = Icon foreground color (overridden per active profile)

settings-modules-power-profiles-icon-bg-color = Icon Background
    .description = Icon container background color

settings-modules-power-profiles-label-show = Show Label
    .description = Display label

settings-modules-power-profiles-label-color = Label Color
    .description = Label text color (overridden per active profile)

settings-modules-power-profiles-label-max-length = Label Max Length
    .description = Max characters before truncation

settings-modules-power-profiles-button-bg-color = Button Background
    .description = Button background color

settings-modules-power-profiles-left-click = Left Click
    .description = Action on left click. Use `:cycle` for the built-in profile cycle, empty for no action, or a shell command

settings-modules-power-profiles-right-click = Right Click
    .description = Shell command on right click

settings-modules-power-profiles-middle-click = Middle Click
    .description = Shell command on middle click

settings-modules-power-profiles-scroll-up = Scroll Up
    .description = Shell command on scroll up

settings-modules-power-profiles-scroll-down = Scroll Down
    .description = Shell command on scroll down
