### Wayle Configuration - Screenshot Module

## Screenshot Module Configuration

settings-modules-screenshot-icon = Icon
    .description = Bar button icon

settings-modules-screenshot-output-directory = Output Directory
    .description = Where screenshots are saved (empty uses the XDG Pictures directory)

settings-modules-screenshot-filename-format = File Name Format
    .description = Saved file name, using strftime specifiers

settings-modules-screenshot-copy-to-clipboard = Copy to Clipboard
    .description = Copy the captured image to the clipboard

settings-modules-screenshot-notify = Notify
    .description = Show a desktop notification after capturing

settings-modules-screenshot-border-show = Show Border
    .description = Display border around button

settings-modules-screenshot-border-color = Border Color
    .description = Border color token

settings-modules-screenshot-icon-show = Show Icon
    .description = Display module icon

settings-modules-screenshot-icon-color = Icon Color
    .description = Icon foreground color

settings-modules-screenshot-icon-bg-color = Icon Background
    .description = Icon container background color

settings-modules-screenshot-label = Label
    .description = Static label text shown beside the icon

settings-modules-screenshot-label-show = Show Label
    .description = Display label

settings-modules-screenshot-label-color = Label Color
    .description = Label text color

settings-modules-screenshot-label-max-length = Label Max Length
    .description = Max characters before truncation

settings-modules-screenshot-button-bg-color = Button Background
    .description = Button background color

settings-modules-screenshot-left-click = Left Click
    .description = Shell command on left click

settings-modules-screenshot-right-click = Right Click
    .description = Shell command on right click

settings-modules-screenshot-middle-click = Middle Click
    .description = Shell command on middle click

settings-modules-screenshot-scroll-up = Scroll Up
    .description = Shell command on scroll up

settings-modules-screenshot-scroll-down = Scroll Down
    .description = Shell command on scroll down
