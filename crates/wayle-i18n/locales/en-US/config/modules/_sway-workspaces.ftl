### Wayle Configuration - Sway Workspaces Module

## Sway Workspaces Module Configuration

settings-modules-sway-workspaces-monitor-specific = Monitor Specific
    .description = Show only workspaces on this monitor

settings-modules-sway-workspaces-hide-trailing-empty = Hide Trailing Empty
    .description = Hide the trailing empty workspace at the end of each output

settings-modules-sway-workspaces-display-mode = Display Mode
    .description = What identifies each workspace (label, icon, or none)

settings-modules-sway-workspaces-label-strategy = Label Strategy
    .description = How to compose the workspace label from name and number

settings-modules-sway-workspaces-divider = Divider
    .description = Text between workspace identity and app icons

settings-modules-sway-workspaces-urgent-show = Show Urgent
    .description = Pulse animation on workspaces with urgent windows

settings-modules-sway-workspaces-urgent-mode = Urgent Mode
    .description = Pulse the whole workspace or only the urgent app icon

settings-modules-sway-workspaces-app-icons-show = Show App Icons
    .description = Display window icons per workspace

settings-modules-sway-workspaces-app-icons-dedupe = Deduplicate Icons
    .description = Show one icon per app_id instead of one per window

settings-modules-sway-workspaces-app-icons-fallback = Fallback Icon
    .description = Icon for windows not matched by app-icon-map

settings-modules-sway-workspaces-app-icons-empty = Empty Icon
    .description = Icon shown when a workspace has no application windows

settings-modules-sway-workspaces-icon-gap = Icon Gap
    .description = Spacing between app icons

settings-modules-sway-workspaces-workspace-padding = Workspace Padding
    .description = Padding along the bar direction

settings-modules-sway-workspaces-icon-size = Icon Size
    .description = Scale multiplier for workspace icons (0.25-3.0)

settings-modules-sway-workspaces-label-size = Label Size
    .description = Scale multiplier for workspace labels (0.25-3.0)

settings-modules-sway-workspaces-workspace-ignore = Ignore Workspaces
    .description = Glob patterns matched against name, number, or id

settings-modules-sway-workspaces-active-indicator = Active Indicator
    .description = Visual style for the active workspace

settings-modules-sway-workspaces-active-color = Active Color
    .description = Color for the active workspace icon and label

settings-modules-sway-workspaces-occupied-color = Occupied Color
    .description = Color for occupied workspace icons and labels

settings-modules-sway-workspaces-empty-color = Empty Color
    .description = Color for empty workspace icons and labels

settings-modules-sway-workspaces-container-bg-color = Container Background
    .description = Background color for the workspaces container

settings-modules-sway-workspaces-border-show = Show Border
    .description = Display border around the workspaces container

settings-modules-sway-workspaces-border-color = Border Color
    .description = Border color for the workspaces container

settings-modules-sway-workspaces-workspace-map = Workspace Map
    .description = Per-workspace icon and color overrides, keyed by name or id

settings-modules-sway-workspaces-app-icon-map = App Icon Map
    .description = Window app_id or title to icon mappings

settings-modules-sway-workspaces-left-click = Left Click
    .description = Action on left click

settings-modules-sway-workspaces-middle-click = Middle Click
    .description = Action on middle click

settings-modules-sway-workspaces-right-click = Right Click
    .description = Action on right click

settings-modules-sway-workspaces-scroll-up = Scroll Up
    .description = Action on scroll up

settings-modules-sway-workspaces-scroll-down = Scroll Down
    .description = Action on scroll down
