### Wayle Configuration - Treeman Module

## Treeman Module Configuration

settings-modules-treeman-format = Label Format
    .description = Format string with placeholders: {"{{ total }}"}, {"{{ stable }}"}, {"{{ up }}"}, {"{{ down }}"}, {"{{ failed }}"}

settings-modules-treeman-icon-name = Icon
    .description = Module icon (shown when no worktree has failed)

settings-modules-treeman-icon-failed = Failed Icon
    .description = Icon shown when any worktree's last finalize errored

settings-modules-treeman-hide-if-empty = Hide If Empty
    .description = Collapse the module when there are no active worktrees

settings-modules-treeman-border-show = Show Border
    .description = Display border around button

settings-modules-treeman-border-color = Border Color
    .description = Border color token

settings-modules-treeman-icon-show = Show Icon
    .description = Display module icon

settings-modules-treeman-icon-color = Icon Color
    .description = Icon foreground color

settings-modules-treeman-icon-bg-color = Icon Background
    .description = Icon container background color

settings-modules-treeman-label-show = Show Label
    .description = Display count label

settings-modules-treeman-label-color = Label Color
    .description = Label text color

settings-modules-treeman-label-max-length = Label Max Length
    .description = Max characters before truncation

settings-modules-treeman-button-bg-color = Button Background
    .description = Button background color

settings-modules-treeman-left-click = Left Click
    .description = Action on left click

settings-modules-treeman-right-click = Right Click
    .description = Action on right click

settings-modules-treeman-middle-click = Middle Click
    .description = Action on middle click

settings-modules-treeman-scroll-up = Scroll Up
    .description = Action on scroll up

settings-modules-treeman-scroll-down = Scroll Down
    .description = Action on scroll down
