settings-share-picker-default-page = Default Page
    .description = Page shown when the screen-share picker opens

settings-share-picker-hide-token-restore = Hide Restore Token
    .description = Hide the "allow a restore token" checkbox

settings-share-picker-width = Width
    .description = Picker window width — a multiplier of the default (1.0) or pixels (e.g. "1200px")

settings-share-picker-height = Height
    .description = Picker window height — a multiplier of the default (1.0) or pixels

settings-share-picker-resize-size = Preview Resolution
    .description = Downscale every captured frame to at most this height in pixels

settings-share-picker-widget-size = Card Image Height
    .description = Height of each card's preview image — a multiplier of the default (1.0) or pixels

settings-share-picker-region-command = Region Command
    .description = Command used to select a region (parsed with shell-word splitting)

settings-share-picker-windows-spacing = Card Spacing
    .description = Spacing between window cards — a multiplier of the default (1.0) or pixels

settings-share-picker-windows-min-per-row = Minimum Per Row
    .description = Minimum window cards per row

settings-share-picker-windows-max-per-row = Maximum Per Row
    .description = Maximum window cards per row

settings-share-picker-outputs-spacing = Card Spacing
    .description = Spacing between output cards (applied per side) — a multiplier of the default (1.0) or pixels

settings-share-picker-outputs-show-label = Show Output Labels
    .description = Show the output name label under each output card

settings-share-picker-outputs-respect-scaling = Respect Scaling
    .description = Scale output cards by their fractional scale


## SharePickerPage variants
enum-share-picker-page-windows = Windows
enum-share-picker-page-outputs = Outputs
enum-share-picker-page-region = Region
