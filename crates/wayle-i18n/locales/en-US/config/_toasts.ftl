

settings-toasts-enabled = Enabled
    .description = Show toast overlays pushed via `wayle toast`.

settings-toasts-position = Position
    .description = Where on screen toasts appear (e.g. top-center, bottom-right)

settings-toasts-text-align = Text Alignment
    .description = Horizontal alignment of toast content

settings-toasts-duration = Duration
    .description = How long a toast stays visible before auto-dismissing (ms)

settings-toasts-monitor = Monitor
    .description = Which monitor shows toasts: "primary" or a connector like "DP-1"

settings-toasts-margin = Margin
    .description = Distance from the screen edge to the toast

settings-toasts-border = Border
    .description = Draw a border around the toast overlay

settings-toasts-layer = Layer
    .description = Layer-shell layer toasts are placed on

settings-toasts-presets = Presets
    .description = Reusable toast presets triggerable with `wayle toast --preset <id>`
